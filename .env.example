# ── Supabase ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Paystack ──────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PAYSTACK_PUBLIC_KEY

# ── Termii (Nigerian SMS OTP) ─────────────────────────────
# Get from https://termii.com
# Only needed if you want SMS OTP (Supabase handles OTP by default)
VITE_TERMII_API_KEY=YOUR_TERMII_KEY

# ── App ───────────────────────────────────────────────────
VITE_APP_NAME=KanoExpress
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_KEY_FOR_PUSH_NOTIFICATIONS
